# 1. 将 DeepSeek 的密钥填入 OPENAI_API_KEY
# 注意：变量名必须是 OPENAI_API_KEY，因为代码底层调用的是 OpenAI 客户端
OPENAI_API_KEY=sk-6604c1024bf04c2d9057d4ff72d39781

# 2. 指定 DeepSeek 的 API 地址
# 这是关键步骤！如果不改这个，程序会默认去连接 openai.com，导致连接失败或扣费错误
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 3. (可选) 指定模型名称
# DeepWiki 可能默认使用 gpt-4o 等，建议显式指定为 deepseek-chat 或 deepseek-reasoner
LLM_MODEL=deepseek-chat

# 降低温度，使输出更确定、更符合格式要求
LLM_TEMPERATURE=0.1
